# ── CatchIt — API Keys ────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your keys.
# The app will warn you at startup if either key is missing.

# SerpApi — used to fetch Google Movies showtimes
# Sign up at https://serpapi.com (free tier: 100 searches/month)
SERPAPI_KEY=your_serpapi_key_here

# Google Maps Platform — used for:
#   • Geocoding API  (theater address → lat/lng)
#   • Directions API (transit travel time from your location to theater)
# Enable both APIs at https://console.cloud.google.com/apis/library
# under "Maps, Routes & Places"
GOOGLE_MAPS_KEY=your_google_maps_key_here

# Optional: change the port (default: 3000)
# PORT=3000
