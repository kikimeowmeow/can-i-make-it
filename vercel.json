{
  "functions": {
    "api/showtimes.js": { "maxDuration": 45 },
    "api/transit.js":   { "maxDuration": 15 },
    "api/geocode.js":   { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/showtimes", "destination": "/api/showtimes.js" },
    { "source": "/api/transit",   "destination": "/api/transit.js"   },
    { "source": "/api/geocode",   "destination": "/api/geocode.js"   },
    { "source": "/(.*)",          "destination": "/index.html"        }
  ]
}
