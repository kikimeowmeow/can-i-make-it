{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js",   "use": "@vercel/node"   }
  ],
  "routes": [
    { "src": "/api/showtimes", "dest": "/api/showtimes.js" },
    { "src": "/api/geocode",   "dest": "/api/geocode.js"   },
    { "src": "/api/transit",   "dest": "/api/transit.js"   },
    { "src": "/",              "dest": "/index.html"        }
  ]
}
